      }
    },
    {
      "name": "bad_sv3_structural",
      "course_id": "course_triangle",
      "description": "Три элемента A→B→C→A через completion_required — структурно недостижимы без стартового прогресса.",
      "expected": {
        "consistency": "passed",
        "acyclicity": "failed",
        "reachability": "failed",
        "violations": [
          {
            "property": "acyclicity",
            "code": "SV2_CYCLE"
