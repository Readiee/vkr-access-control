        "consistency": "passed",
        "acyclicity": "passed",
        "reachability": "passed",
        "redundancy": "passed",
        "subsumption": "passed"
      },
      "access_matrix_reference": "SAT_DATA_MODELS §6.7"
    },
    {
      "name": "bad_sv1_disjointness",
      "course_id": "course_minimal",
      "description": "user_mixed_role ∈ Student ⊓ Methodologist — нарушение AllDisjoint (§1.5).",
      "expected": {
        "consistency": "failed",
        "violations": [
          {
            "property": "consistency",
            "code": "SV1_INCONSISTENT",
            "root_individual": "user_mixed_role"
          }
        ]
      }
    },
    {
