      "expected": {
        "consistency": "passed",
        "acyclicity": "passed",
        "reachability": "failed",
        "violations": [
          {
            "property": "reachability",
            "code": "SV3_ATOMIC_UNSAT",
            "policy_id": "p_unreach_threshold"
          }
        ]
      }
    },
    {
      "name": "bad_sv3_empty_date",
      "course_id": "course_empty_window",
      "description": "date_restricted с valid_from > valid_until — пустое окно.",
      "expected": {
        "consistency": "passed",
        "acyclicity": "passed",
        "reachability": "failed",
        "violations": [
          {
            "property": "reachability",
            "code": "SV3_ATOMIC_UNSAT",
            "policy_id": "p_unreach_date"
