    </rdf:Description>
  </swrl:head>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#CourseStructure"/>
          <swrl:argument1 rdf:resource="urn:swrl#element"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#has_access_policy"/>
              <swrl:argument1 rdf:resource="urn:swrl#element"/>
              <swrl:argument2 rdf:resource="urn:swrl#policy"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:DatavaluedPropertyAtom>
                  <swrl:propertyPredicate rdf:resource="#is_active"/>
                  <swrl:argument1 rdf:resource="urn:swrl#policy"/>
                  <swrl:argument2 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrl:argument2>
                </swrl:DatavaluedPropertyAtom>
              </rdf:first>
              <rdf:rest>
                <rdf:Description>
                  <rdf:first>
                    <swrl:DatavaluedPropertyAtom>
                      <swrl:propertyPredicate rdf:resource="#rule_type"/>
                      <swrl:argument1 rdf:resource="urn:swrl#policy"/>
                      <swrl:argument2 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">grade_required</swrl:argument2>
                    </swrl:DatavaluedPropertyAtom>
                  </rdf:first>
                  <rdf:rest>
                    <rdf:Description>
                      <rdf:first>
                        <swrl:IndividualPropertyAtom>
                          <swrl:propertyPredicate rdf:resource="#targets_element"/>
                          <swrl:argument1 rdf:resource="urn:swrl#policy"/>
                          <swrl:argument2 rdf:resource="urn:swrl#target_elem"/>
                        </swrl:IndividualPropertyAtom>
                      </rdf:first>
                      <rdf:rest>
                        <rdf:Description>
                          <rdf:first>
                            <swrl:DatavaluedPropertyAtom>
                              <swrl:propertyPredicate rdf:resource="#passing_threshold"/>
                              <swrl:argument1 rdf:resource="urn:swrl#policy"/>
                              <swrl:argument2 rdf:resource="urn:swrl#threshold"/>
                            </swrl:DatavaluedPropertyAtom>
                          </rdf:first>
                          <rdf:rest>
                            <rdf:Description>
                              <rdf:first>
                                <swrl:ClassAtom>
                                  <swrl:classPredicate rdf:resource="#Student"/>
                                  <swrl:argument1 rdf:resource="urn:swrl#student"/>
                                </swrl:ClassAtom>
                              </rdf:first>
                              <rdf:rest>
                                <rdf:Description>
                                  <rdf:first>
                                    <swrl:IndividualPropertyAtom>
                                      <swrl:propertyPredicate rdf:resource="#has_progress_record"/>
                                      <swrl:argument1 rdf:resource="urn:swrl#student"/>
                                      <swrl:argument2 rdf:resource="urn:swrl#pr"/>
                                    </swrl:IndividualPropertyAtom>
                                  </rdf:first>
                                  <rdf:rest>
                                    <rdf:Description>
                                      <rdf:first>
                                        <swrl:IndividualPropertyAtom>
                                          <swrl:propertyPredicate rdf:resource="#refers_to_element"/>
                                          <swrl:argument1 rdf:resource="urn:swrl#pr"/>
                                          <swrl:argument2 rdf:resource="urn:swrl#target_elem"/>
                                        </swrl:IndividualPropertyAtom>
                                      </rdf:first>
                                      <rdf:rest>
                                        <rdf:Description>
                                          <rdf:first>
                                            <swrl:DatavaluedPropertyAtom>
                                              <swrl:propertyPredicate rdf:resource="#has_grade"/>
                                              <swrl:argument1 rdf:resource="urn:swrl#pr"/>
                                              <swrl:argument2 rdf:resource="urn:swrl#grade"/>
                                            </swrl:DatavaluedPropertyAtom>
                                          </rdf:first>
                                          <rdf:rest>
                                            <rdf:Description>
                                              <rdf:first>
                                                <swrl:BuiltinAtom>
                                                  <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#greaterThanOrEqual"/>
                                                  <swrl:arguments>
                                                    <rdf:Description>
                                                      <rdf:first rdf:resource="urn:swrl#grade"/>
                                                      <rdf:rest>
                                                        <rdf:Description>
                                                          <rdf:first rdf:resource="urn:swrl#threshold"/>
                                                          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                        </rdf:Description>
                                                      </rdf:rest>
                                                    </rdf:Description>
                                                  </swrl:arguments>
                                                </swrl:BuiltinAtom>
                                              </rdf:first>
                                              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </rdf:Description>
                                          </rdf:rest>
                                        </rdf:Description>
                                      </rdf:rest>
                                    </rdf:Description>
                                  </rdf:rest>
                                </rdf:Description>
                              </rdf:rest>
                            </rdf:Description>
                          </rdf:rest>
                        </rdf:Description>
                      </rdf:rest>
                    </rdf:Description>
                  </rdf:rest>
                </rdf:Description>
              </rdf:rest>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#is_available_for"/>
          <swrl:argument1 rdf:resource="urn:swrl#element"/>
          <swrl:argument2 rdf:resource="urn:swrl#student"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Student"/>
          <swrl:argument1 rdf:resource="urn:swrl#s"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#has_competency"/>
              <swrl:argument1 rdf:resource="urn:swrl#s"/>
              <swrl:argument2 rdf:resource="urn:swrl#sub"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:IndividualPropertyAtom>
                  <swrl:propertyPredicate rdf:resource="#is_subcompetency_of"/>
                  <swrl:argument1 rdf:resource="urn:swrl#sub"/>
                  <swrl:argument2 rdf:resource="urn:swrl#parent"/>
                </swrl:IndividualPropertyAtom>
              </rdf:first>
              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#has_competency"/>
          <swrl:argument1 rdf:resource="urn:swrl#s"/>
          <swrl:argument2 rdf:resource="urn:swrl#parent"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
