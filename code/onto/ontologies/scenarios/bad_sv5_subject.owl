<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/edu_ontology.owl"
         xmlns="http://example.org/edu_ontology.owl#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://example.org/edu_ontology.owl"/>

<owl:ObjectProperty rdf:about="#is_contained_in_course">
  <rdfs:domain rdf:resource="#Module"/>
  <rdfs:range rdf:resource="#Course"/>
  <owl:inverseOf rdf:resource="#has_module"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_module">
  <rdfs:domain rdf:resource="#Course"/>
  <rdfs:range rdf:resource="#Module"/>
  <owl:inverseOf rdf:resource="#is_contained_in_course"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_contained_in_module">
  <rdfs:domain rdf:resource="#LearningActivity"/>
  <rdfs:range rdf:resource="#Module"/>
  <owl:inverseOf rdf:resource="#contains_activity"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#contains_activity">
  <rdfs:domain rdf:resource="#Module"/>
  <rdfs:range rdf:resource="#LearningActivity"/>
  <owl:inverseOf rdf:resource="#is_contained_in_module"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_progress_record">
  <rdfs:domain rdf:resource="#Student"/>
  <rdfs:range rdf:resource="#ProgressRecord"/>
  <owl:inverseOf rdf:resource="#refers_to_student"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#refers_to_student">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#ProgressRecord"/>
  <rdfs:range rdf:resource="#Student"/>
  <owl:inverseOf rdf:resource="#has_progress_record"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#refers_to_element">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#ProgressRecord"/>
  <rdfs:range rdf:resource="#CourseStructure"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_status">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#ProgressRecord"/>
  <rdfs:range rdf:resource="#Status"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#assesses">
  <rdfs:domain rdf:resource="#CourseStructure"/>
  <rdfs:range rdf:resource="#Competency"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_competency">
  <rdfs:domain rdf:resource="#Student"/>
  <rdfs:range rdf:resource="#Competency"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#targets_competency">
  <rdfs:domain rdf:resource="#AccessPolicy"/>
  <rdfs:range rdf:resource="#Competency"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_subcompetency_of">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
  <rdfs:domain rdf:resource="#Competency"/>
  <rdfs:range rdf:resource="#Competency"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_access_policy">
  <rdfs:domain rdf:resource="#CourseStructure"/>
  <rdfs:range rdf:resource="#AccessPolicy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#targets_element">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AccessPolicy"/>
  <rdfs:range rdf:resource="#CourseStructure"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_author">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AccessPolicy"/>
  <rdfs:range rdf:resource="#Methodologist"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_subpolicy">
  <rdfs:domain rdf:resource="#AccessPolicy"/>
  <rdfs:range rdf:resource="#AccessPolicy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#belongs_to_group">
  <rdfs:domain rdf:resource="#Student"/>
  <rdfs:range rdf:resource="#Group"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#restricted_to_group">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AccessPolicy"/>
  <rdfs:range rdf:resource="#Group"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#aggregate_elements">
  <rdfs:domain rdf:resource="#AccessPolicy"/>
  <rdfs:range rdf:resource="#CourseStructure"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#for_student">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AggregateFact"/>
  <rdfs:range rdf:resource="#Student"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#for_policy">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AggregateFact"/>
  <rdfs:range rdf:resource="#AccessPolicy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#satisfies">
  <rdfs:domain rdf:resource="#Student"/>
  <rdfs:range rdf:resource="#AccessPolicy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_available_for">
  <rdfs:domain rdf:resource="#CourseStructure"/>
  <rdfs:range rdf:resource="#Student"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#is_active">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AccessPolicy"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#is_mandatory">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#CourseStructure"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#order_index">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#CourseStructure"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#rule_type">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AccessPolicy"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#passing_threshold">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AccessPolicy"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#valid_from">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AccessPolicy"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#valid_until">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AccessPolicy"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#has_grade">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#ProgressRecord"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#failed_attempts_count">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#ProgressRecord"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#started_at">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#ProgressRecord"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#completed_at">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#ProgressRecord"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#has_value">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#CurrentTime"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#aggregate_function">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AccessPolicy"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#computed_value">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#AggregateFact"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Module">
  <rdfs:subClassOf rdf:resource="#CourseStructure"/>
</owl:Class>

<owl:Class rdf:about="#Course">
  <rdfs:subClassOf rdf:resource="#CourseStructure"/>
</owl:Class>

<owl:Class rdf:about="#LearningActivity">
  <rdfs:subClassOf rdf:resource="#CourseStructure"/>
</owl:Class>

<owl:Class rdf:about="#Student">
  <rdfs:subClassOf rdf:resource="#User"/>
</owl:Class>

<owl:Class rdf:about="#ProgressRecord">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#CourseStructure">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Status">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Competency">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#AccessPolicy">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Methodologist">
  <rdfs:subClassOf rdf:resource="#User"/>
</owl:Class>

<owl:Class rdf:about="#Group">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#AggregateFact">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#CurrentTime">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#User">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Teacher">
  <rdfs:subClassOf rdf:resource="#User"/>
</owl:Class>

<owl:Class rdf:about="#SandboxStudent">
  <rdfs:subClassOf rdf:resource="#Student"/>
</owl:Class>

<owl:Class rdf:about="#Lecture">
  <rdfs:subClassOf rdf:resource="#LearningActivity"/>
</owl:Class>

<owl:Class rdf:about="#Test">
  <rdfs:subClassOf rdf:resource="#LearningActivity"/>
</owl:Class>

<owl:Class rdf:about="#Assignment">
  <rdfs:subClassOf rdf:resource="#LearningActivity"/>
</owl:Class>

<owl:Class rdf:about="#Practice">
  <rdfs:subClassOf rdf:resource="#LearningActivity"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#status_passed">
  <rdf:type rdf:resource="#Status"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#status_viewed">
  <rdf:type rdf:resource="#Status"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#status_completed">
  <rdf:type rdf:resource="#Status"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#status_failed">
  <rdf:type rdf:resource="#Status"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#methodologist_smirnov">
  <rdf:type rdf:resource="#Methodologist"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#course_subject">
  <rdf:type rdf:resource="#Course"/>
  <has_module rdf:resource="#module_one"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#module_one">
  <rdf:type rdf:resource="#Module"/>
  <contains_activity rdf:resource="#elem_s"/>
  <contains_activity rdf:resource="#quiz_subj_prereq"/>
  <is_mandatory rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</is_mandatory>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#quiz_subj_prereq">
  <rdf:type rdf:resource="#Test"/>
  <is_mandatory rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</is_mandatory>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#elem_s">
  <rdf:type rdf:resource="#Lecture"/>
  <has_access_policy rdf:resource="#p_subj_all"/>
  <has_access_policy rdf:resource="#p_subj_group"/>
  <is_mandatory rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</is_mandatory>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#grp_advanced">
  <rdf:type rdf:resource="#Group"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#p_subj_all">
  <rdf:type rdf:resource="#AccessPolicy"/>
  <has_author rdf:resource="#methodologist_smirnov"/>
  <targets_element rdf:resource="#quiz_subj_prereq"/>
  <rule_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">grade_required</rule_type>
  <is_active rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</is_active>
  <passing_threshold rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">70.0</passing_threshold>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#p_subj_group_sub_grade">
  <rdf:type rdf:resource="#AccessPolicy"/>
  <has_author rdf:resource="#methodologist_smirnov"/>
  <targets_element rdf:resource="#quiz_subj_prereq"/>
  <rule_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">grade_required</rule_type>
  <is_active rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</is_active>
  <passing_threshold rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">70.0</passing_threshold>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#p_subj_group_sub_group">
  <rdf:type rdf:resource="#AccessPolicy"/>
  <has_author rdf:resource="#methodologist_smirnov"/>
  <restricted_to_group rdf:resource="#grp_advanced"/>
  <rule_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">group_restricted</rule_type>
  <is_active rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</is_active>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#p_subj_group">
  <rdf:type rdf:resource="#AccessPolicy"/>
  <has_author rdf:resource="#methodologist_smirnov"/>
  <has_subpolicy rdf:resource="#p_subj_group_sub_group"/>
  <has_subpolicy rdf:resource="#p_subj_group_sub_grade"/>
  <rule_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">and_combination</rule_type>
  <is_active rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</is_active>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#student_any">
  <rdf:type rdf:resource="#Student"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#student_advanced">
  <rdf:type rdf:resource="#Student"/>
  <belongs_to_group rdf:resource="#grp_advanced"/>
</owl:NamedIndividual>

<swrl:Variable rdf:about="urn:swrl#s"/>

<swrl:Variable rdf:about="urn:swrl#sub"/>

<swrl:Variable rdf:about="urn:swrl#parent"/>

<swrl:Variable rdf:about="urn:swrl#p"/>

<swrl:Variable rdf:about="urn:swrl#target"/>

<swrl:Variable rdf:about="urn:swrl#pr"/>

<swrl:Variable rdf:about="urn:swrl#th"/>

<swrl:Variable rdf:about="urn:swrl#g"/>

<swrl:Variable rdf:about="urn:swrl#req_comp"/>

<swrl:Variable rdf:about="urn:swrl#from"/>

<swrl:Variable rdf:about="urn:swrl#until"/>

<swrl:Variable rdf:about="urn:swrl#now_ind"/>

<swrl:Variable rdf:about="urn:swrl#now"/>

<swrl:Variable rdf:about="urn:swrl#f"/>

<swrl:Variable rdf:about="urn:swrl#val"/>

<swrl:Variable rdf:about="urn:swrl#sub1"/>

<swrl:Variable rdf:about="urn:swrl#sub2"/>

<swrl:Variable rdf:about="urn:swrl#sub3"/>

<swrl:Variable rdf:about="urn:swrl#el"/>

<owl:AllDifferent>
  <owl:distinctMembers rdf:parseType="Collection">
    <rdf:Description rdf:about="#p_subj_group_sub_grade"/>
    <rdf:Description rdf:about="#p_subj_group_sub_group"/>
  </owl:distinctMembers>
</owl:AllDifferent>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#User"/>
    <rdf:Description rdf:about="#CourseStructure"/>
    <rdf:Description rdf:about="#Group"/>
    <rdf:Description rdf:about="#ProgressRecord"/>
    <rdf:Description rdf:about="#Competency"/>
    <rdf:Description rdf:about="#AccessPolicy"/>
    <rdf:Description rdf:about="#Status"/>
    <rdf:Description rdf:about="#CurrentTime"/>
    <rdf:Description rdf:about="#AggregateFact"/>
  </owl:members>
</owl:AllDisjointClasses>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#Lecture"/>
    <rdf:Description rdf:about="#Test"/>
    <rdf:Description rdf:about="#Assignment"/>
    <rdf:Description rdf:about="#Practice"/>
  </owl:members>
</owl:AllDisjointClasses>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#Course"/>
    <rdf:Description rdf:about="#Module"/>
    <rdf:Description rdf:about="#LearningActivity"/>
  </owl:members>
</owl:AllDisjointClasses>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#Student"/>
    <rdf:Description rdf:about="#Teacher"/>
    <rdf:Description rdf:about="#Methodologist"/>
  </owl:members>
</owl:AllDisjointClasses>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Student"/>
          <swrl:argument1 rdf:resource="urn:swrl#s"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#has_competency"/>
              <swrl:argument1 rdf:resource="urn:swrl#s"/>
              <swrl:argument2 rdf:resource="urn:swrl#sub"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:IndividualPropertyAtom>
                  <swrl:propertyPredicate rdf:resource="#is_subcompetency_of"/>
                  <swrl:argument1 rdf:resource="urn:swrl#sub"/>
                  <swrl:argument2 rdf:resource="urn:swrl#parent"/>
                </swrl:IndividualPropertyAtom>
              </rdf:first>
              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#has_competency"/>
          <swrl:argument1 rdf:resource="urn:swrl#s"/>
          <swrl:argument2 rdf:resource="urn:swrl#parent"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#AccessPolicy"/>
          <swrl:argument1 rdf:resource="urn:swrl#p"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:DatavaluedPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#is_active"/>
              <swrl:argument1 rdf:resource="urn:swrl#p"/>
              <swrl:argument2 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrl:argument2>
            </swrl:DatavaluedPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:DatavaluedPropertyAtom>
                  <swrl:propertyPredicate rdf:resource="#rule_type"/>
                  <swrl:argument1 rdf:resource="urn:swrl#p"/>
                  <swrl:argument2 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">viewed_required</swrl:argument2>
                </swrl:DatavaluedPropertyAtom>
              </rdf:first>
              <rdf:rest>
                <rdf:Description>
                  <rdf:first>
                    <swrl:IndividualPropertyAtom>
                      <swrl:propertyPredicate rdf:resource="#targets_element"/>
                      <swrl:argument1 rdf:resource="urn:swrl#p"/>
                      <swrl:argument2 rdf:resource="urn:swrl#target"/>
                    </swrl:IndividualPropertyAtom>
                  </rdf:first>
                  <rdf:rest>
                    <rdf:Description>
                      <rdf:first>
                        <swrl:ClassAtom>
                          <swrl:classPredicate rdf:resource="#Student"/>
                          <swrl:argument1 rdf:resource="urn:swrl#s"/>
                        </swrl:ClassAtom>
                      </rdf:first>
                      <rdf:rest>
                        <rdf:Description>
                          <rdf:first>
                            <swrl:IndividualPropertyAtom>
                              <swrl:propertyPredicate rdf:resource="#has_progress_record"/>
                              <swrl:argument1 rdf:resource="urn:swrl#s"/>
                              <swrl:argument2 rdf:resource="urn:swrl#pr"/>
                            </swrl:IndividualPropertyAtom>
                          </rdf:first>
                          <rdf:rest>
                            <rdf:Description>
                              <rdf:first>
                                <swrl:IndividualPropertyAtom>
                                  <swrl:propertyPredicate rdf:resource="#refers_to_element"/>
                                  <swrl:argument1 rdf:resource="urn:swrl#pr"/>
                                  <swrl:argument2 rdf:resource="urn:swrl#target"/>
                                </swrl:IndividualPropertyAtom>
                              </rdf:first>
                              <rdf:rest>
