                                      </rdf:first>
                                      <rdf:rest>
                                        <rdf:Description>
                                          <rdf:first>
                                            <swrl:DatavaluedPropertyAtom>
                                              <swrl:propertyPredicate rdf:resource="#has_grade"/>
                                              <swrl:argument1 rdf:resource="urn:swrl#pr"/>
                                              <swrl:argument2 rdf:resource="urn:swrl#grade"/>
                                            </swrl:DatavaluedPropertyAtom>
                                          </rdf:first>
                                          <rdf:rest>
                                            <rdf:Description>
                                              <rdf:first>
                                                <swrl:BuiltinAtom>
                                                  <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#greaterThanOrEqual"/>
                                                  <swrl:arguments>
                                                    <rdf:Description>
                                                      <rdf:first rdf:resource="urn:swrl#grade"/>
