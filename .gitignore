# ── Тестовые артефакты онтологии ──────────────────────────────────────
# Integration-тесты создают временные .owl в системный tmp-dir; страховка
# от прогонов прошлых версий, где файл оседал в дереве тестов.
code/backend/src/tests/**/*.owl

# ── Claude Code рабочие артефакты ────────────────────────────────────
.claude/scheduled_tasks.lock
