%%{init: {'theme': 'default', 'themeVariables': {'fontFamily': 'Segoe UI'}}}%%
flowchart LR
    %% =========================================================
    %% Актёры
    %% =========================================================
    M((Методист))
    A((Администратор))
    LMS([Внешняя СДО])

    %% =========================================================
    %% Границы системы
    %% =========================================================
    subgraph SystemBox["Система управления политиками доступа"]
        direction TB

        subgraph Mgmt["Управление политиками"]
            direction TB
            UC1["UC-1<br/>Создать политику"]
            UC2["UC-2<br/>Редактировать политику"]
            UC2a["UC-2a<br/>Удалить политику"]
            UC3["UC-3<br/>Валидация политики"]
        end

        subgraph Exec["Исполнение"]
            direction TB
            UC4["UC-4<br/>Проверить доступ"]
            UC5["UC-5<br/>Зафиксировать событие прогресса"]
            UC8["UC-8<br/>Каскадная агрегация завершённости"]
            UC9["UC-9<br/>Объяснение блокировки"]
        end

        subgraph Verify["Верификация"]
            UC6["UC-6<br/>Полная верификация курса"]
        end

        subgraph SandboxBox["Песочница"]
            direction TB
            UC7a["UC-7a<br/>Создать тестового студента"]
            UC7b["UC-7b<br/>Изменить факты студента"]
            UC7c["UC-7c<br/>Просмотреть карту доступов"]
        end

        subgraph Integ["Интеграция"]
            UC10["UC-10<br/>Импортировать курс<br/>со структурой и политиками"]
        end
    end

    %% =========================================================
    %% Связи актёров с прецедентами
    %% =========================================================
    M --> UC1
    M --> UC2
    M --> UC2a
    M --> UC6
    M --> UC7a
    M --> UC7b
    M --> UC7c

    A --> UC10
    A --> UC6

    LMS --> UC4
    LMS --> UC5

    %% =========================================================
    %% Include и extend
    %% =========================================================
    UC1  -.->|include| UC3
    UC2  -.->|include| UC3
    UC5  -.->|include| UC8
    UC7c -.->|include| UC4
    UC10 -.->|include| UC6
    UC9 -.->|extend| UC4
    UC9 -.->|extend| UC7c

    classDef actor fill:#fff8e7,stroke:#a07a14,color:#5a4400
    classDef ext   fill:#eef2ff,stroke:#5a6acf,color:#1a1f4a
    classDef uc    fill:#f4faf6,stroke:#2e8b57,color:#0b3d1e
    class M,A actor
    class LMS ext
    class UC1,UC2,UC2a,UC3,UC4,UC5,UC6,UC7a,UC7b,UC7c,UC8,UC9,UC10 uc
