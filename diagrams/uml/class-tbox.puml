@startuml class-tbox
!theme plain
skinparam defaultFontName "Segoe UI"
skinparam dpi 150
skinparam classAttributeIconSize 0
skinparam classBackgroundColor White
skinparam classBorderColor Black
skinparam classFontStyle bold
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 50

title Класс-диаграмма TBox онтологии управления доступом (OWL 2 DL)

' ============================================================
' 1. USERS
' ============================================================
package "Пользователи" as PkgUsers {
    abstract class User
    class Student
    class SandboxStudent <<sandbox>>
    class Teacher
    class Methodologist

    User <|-- Student
    Student <|-- SandboxStudent
    User <|-- Teacher
    User <|-- Methodologist
}

' ============================================================
' 2. COURSE STRUCTURE
' ============================================================
package "Структура курса" as PkgStruct {
    abstract class CourseStructure {
        order_index : int <<f>>
        is_mandatory : bool <<f>>
    }
    class Course
    class Module
    class LearningActivity
    class Lecture
    class Test
    class Assignment
    class Practice

    CourseStructure <|-- Course
    CourseStructure <|-- Module
    CourseStructure <|-- LearningActivity
    LearningActivity <|-- Lecture
    LearningActivity <|-- Test
    LearningActivity <|-- Assignment
    LearningActivity <|-- Practice
}

' ============================================================
' 3. PROGRESS / STATUS / COMPETENCY / GROUP
' ============================================================
package "Прогресс и домен" as PkgProg {
    class ProgressRecord {
        has_grade : float <<f>>
        started_at : dateTime <<f>>
        completed_at : dateTime <<f>>
        failed_attempts_count : int <<f>>
    }

    enum Status {
        status_viewed
        status_completed
        status_failed
        status_passed
    }

    class Competency
    class Group
}

' ============================================================
' 4. ACCESS POLICY
' ============================================================
package "Управление доступом" as PkgAC {
    class AccessPolicy {
        is_active : bool <<f>>
        rule_type : string <<f>>
        passing_threshold : float <<f>>
        valid_from : dateTime <<f>>
        valid_until : dateTime <<f>>
        aggregate_function : string <<f>>
    }
}

' ============================================================
' 5. ENRICHER-INJECTED (LIM1, LIM2 compensation)
' ============================================================
package "Enricher-инжекции" as PkgEnr {
    class CurrentTime <<enricher>> {
        has_value : dateTime <<f>>
    }
    class AggregateFact <<enricher>> {
        computed_value : float <<f>>
    }
}

' ============================================================
' === RELATIONS: HIERARCHY ===
' ============================================================
Course "1" *--> "0..*" Module : has_module
Module "1" *--> "0..*" LearningActivity : contains_activity

' ============================================================
' === RELATIONS: PROGRESS ===
' ============================================================
Student "1" *--> "0..*" ProgressRecord : has_progress_record
ProgressRecord --> CourseStructure : refers_to_element <<f>>
ProgressRecord --> Status : has_status <<f>>

' ============================================================
' === RELATIONS: COMPETENCY ===
' ============================================================
Student --> Competency : has_competency
CourseStructure --> Competency : assesses
Competency --> Competency : is_subcompetency_of\n<<transitive>>

' ============================================================
' === RELATIONS: GROUP ===
' ============================================================
Student "1" --> "0..*" Group : belongs_to_group
Group --> Group : is_subgroup_of\n<<transitive>>

' ============================================================
' === RELATIONS: ACCESS POLICY ===
' ============================================================
CourseStructure "1" o--> "0..*" AccessPolicy : has_access_policy
AccessPolicy --> CourseStructure : targets_element <<f>>
AccessPolicy --> Methodologist : has_author <<f>>
AccessPolicy --> AccessPolicy : has_subpolicy\n(AND / OR)
AccessPolicy --> Competency : targets_competency
AccessPolicy --> Group : restricted_to_group <<f>>
AccessPolicy --> CourseStructure : aggregate_elements

' ============================================================
' === RELATIONS: ENRICHER LINKS ===
' ============================================================
AggregateFact --> Student : for_student <<f>>
AggregateFact --> AccessPolicy : for_policy <<f>>

' ============================================================
' === RELATIONS: INFERRED (SWRL) ===
' ============================================================
Student ..> AccessPolicy : <<inferred>>\nsatisfies
CourseStructure ..> Student : <<inferred>>\nis_available_for

' ============================================================
' NOTES
' ============================================================
note right of AccessPolicy
  **rule_type ∈** {
    completion_required,
    grade_required,
    viewed_required,
    competency_required,
    date_restricted,
    and_combination,
    or_combination,
    group_restricted,
    aggregate_required
  }
end note

note bottom of CurrentTime
  Singleton-индивид **current_time_ind**,
  пересоздаваемый enricher-ом
  перед каждым reasoning-прогоном (LIM1).
end note

note bottom of AggregateFact
  По одному индивиду
  на пару (Student × AccessPolicy) типа
  aggregate_required. Пересчитывается
  enricher-ом перед каждым прогоном (LIM2).
end note

note right of Status
  Enum: 4 named individuals.
  Связь через object property
  **has_status** (functional).
end note

' ============================================================
' TRACEABILITY: класс онтологии ← источник из главы 1 → артефакт главы 2
' ============================================================
note as TraceMatrix
  **Трассируемость классов TBox (глава 1 → глава 2)**
  | **Класс** | **Источник (глава 1)** | **Артефакт (глава 2)** |
  | Student | Стейкхолдер §2.7.1; Moodle `user`, Canvas `user`, Open edX `auth_user` (L1 слой 3) | UC-4, UC-5, UC-7; ФТ-2, ФТ-4, ФТ-7 |
  | SandboxStudent | UC-7 симулятор: тестовый студент методиста для прогона сценариев без побочных эффектов на реальный прогресс | UC-7a, UC-7b, UC-7c; ФТ-7 |
  | Teacher | Стейкхолдер §2.7.1 «преподаватель» | Справочно; вне scope AC (см. §2.4) |
  | Methodologist | Стейкхолдер §2.7.1 «методист»; as-is §2.7.2 сценарий 1 | UC-1, UC-2, UC-3, UC-6, UC-7; has_author |
  | Course | L1 таблица СДО: контейнер верхнего уровня во всех 5 платформах | UC-10 импорт; ФТ-1.5 уровни иерархии |
  | Module | L1: Moodle section, Canvas module, Open edX subsection, Blackboard content folder | ФТ-1.5; UC-10 |
  | LearningActivity | L1: Moodle activity, Canvas item, Stepik step, Open edX unit (решение 20.04 о переименовании) | ФТ-1.5; атомарная единица для политик |
  | Lecture/Test/Assignment/Practice | Таксономия контента Moodle/Canvas (P12, P17) | ABox демо-курса §6 SAT_DATA_MODELS |
  | ProgressRecord | L1: Moodle `course_modules_completion` + `grade_grades`; xAPI statement (P7) | UC-5 события прогресса; ФТ-4.2 |
  | Status | L1: состояния completion в Moodle/Canvas/Blackboard | UC-8 rollup; алгоритм А3 |
  | Competency | L1: Moodle competency framework, Canvas Outcomes | Тип правила 4; F4; тезис OWL-преимущества (2.2) |
  | Group | L1: Moodle groups (+ groupings), Canvas differentiation tags, Blackboard adaptive | Тип правила 8 group_restricted; FIX8; иерархия через is_subgroup_of |
  | AccessPolicy | §2.7.2 P1 (семантика правил задаётся кодом) + пул §2.5 | Ядро 9 типов; FT-1; все UC |
  | CurrentTime | LIM1 (нет now() в SWRL); §2.3 матрица F5 | Enricher R2; FIX11; тип правила 5 |
  | AggregateFact | LIM2 (нет агрегаций в SWRL); §2.3 матрица F10 | Enricher R4; FIX12; тип правила 9 |

  **Трассируемость свойств:**
  satisfies, has_subpolicy — двухуровневая SWRL (решение 20.04); СВ-4/5 (решение 21.04).
  is_available_for — итоговый predicate CWA-enforcement (LIM5, Carminati 2011).
  belongs_to_group (0..*), restricted_to_group, is_subgroup_of — ФТ-1.1 тип 8; L1 Moodle/Canvas.
  targets_competency, is_subcompetency_of — ФТ-1.1 тип 4; TransitiveProperty (F4, Moodle competencies).
end note

' ============================================================
' LEGEND
' ============================================================
legend bottom right
  **Обозначения**
  <<f>>                   — Functional property
  **жирная стрелка**        — asserted object property
  <u>пунктирная стрелка</u> — SWRL-inferred property
  **◆**                   — композиция (иерархия курса)
  **◇**                   — агрегация (политика на элементе)
  ----
  **Дизъюнктность классов:**
  Student ⊓ Teacher ⊓ Methodologist ⊑ ⊥
  Course ⊓ Module ⊓ LearningActivity ⊑ ⊥
  Lecture ⊓ Test ⊓ Assignment ⊓ Practice ⊑ ⊥
  (все корневые классы попарно)
endlegend

@enduml
