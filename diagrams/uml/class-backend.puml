@startuml class-backend
!theme plain
skinparam defaultFontName "Segoe UI"
skinparam dpi 150
skinparam classAttributeIconSize 0
skinparam classBackgroundColor White
skinparam classBorderColor Black
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 35
skinparam ranksep 45



' =========================================================
' SERVICE LAYER (бизнес-логика)
' =========================================================
package "Service Layer" as PkgSrv {
    class PolicyService {
        - core : OntologyCore
        - reasoner : ReasoningOrchestrator
        - cache : CacheManager
        + create_policy(data) : Policy
        + get_policies(course_id?, element_id?) : list<Policy>
        + update_policy(id, data) : Policy
        + delete_policy(id) : bool
        + toggle_policy(id, active) : void
    }

    class AccessService {
        - core : OntologyCore
        - cache : CacheManager
        - reasoner : ReasoningOrchestrator
        - explainer : AccessExplainer
        + rebuild_student_access(sid) : dict
        + get_course_access(sid, cid) : AvailableElements
        + explain_blocking(sid, eid) : dict
    }

    class VerificationService {
        - core : OntologyCore
        - reasoner : ReasoningOrchestrator
        - cache : CacheManager
        + verify(course_id, include_subsumption) : VerificationReport
    }

    class ProgressService {
        - core : OntologyCore
        - reasoner : ReasoningOrchestrator
        - rollup : RollupService
        - access : AccessService
        + register_progress(event) : dict
        + update_progress(sid, eid, status) : void
        + rerun_reasoning_and_rebuild_cache(sid) : void
        + invalidate_student_cache(sid) : dict
        + get_student_access(sid, cid) : dict
    }

    class SandboxService {
        - core : OntologyCore
        - reasoner : ReasoningOrchestrator
        - access : AccessService
        - progress : ProgressService
        + get_sandbox_state(cid) : dict
        + simulate_progress(payload) : dict
        + rollback_progress(eid) : dict
        + reset_all() : dict
        + set_competencies(ids) : dict
        + set_groups(ids) : dict
    }

    class RollupService {
        - core : OntologyCore
        + execute(student, child_element, update_callback) : void
    }

    class IntegrationService {
        - core : OntologyCore
        - verification : VerificationService
        - cache : CacheManager
        + sync_course_structure(cid, payload) : dict
        + get_meta() : OntologyMeta
        + get_course_tree(cid) : list<CourseTreeNode>
        + set_element_competencies(eid, ids) : dict
        + set_element_mandatory(eid, flag) : dict
    }
}

' =========================================================
' CORE LAYER (инфраструктура)
' =========================================================
package "Core Layer" as PkgCore {
    class OntologyCore {
        - onto : Ontology
        - path : str
        + load() : void
        + save() : void
        + find_by_id(id) : Individual
        + create_individual(cls, id) : Individual
        + delete_individual(ind) : void
    }

    class ReasoningOrchestrator <<А2>> {
        - core : OntologyCore
        - timeout_s : int = 10
        + reason_and_materialize(student_id?) : ReasonResult
        - _pre_enrich() : void
        - _reason() : void
        - _post_enforce(student) : set<Element>
        - _materialize(student, accessible) : void
    }

    class GraphValidator <<А1, А4>> <<utility>> {
        + {static} check_for_cycles(onto, src, probe?) : list<Element>
        + {static} find_all_cycles(onto) : list<list<Element>>
        + {static} find_all_unreachable(onto) : list<UnreachableReport>
        + {static} get_parent_of(onto, eid) : str?
    }

    class CacheManager <<А5>> {
        - redis : Redis
        + get_student_access(id) : dict?
        + set_student_access(id, map, ttl) : void
        + invalidate_student(id) : void
        + invalidate_all_access() : void
        - _compute_ttl(student) : int
    }

    class AccessExplainer {
        - core : OntologyCore
        + explain_blocking(sid, eid) : dict
    }
}

' =========================================================
' SCHEMAS (Pydantic DTOs)
' =========================================================
package "Schemas" as PkgSch {
    class PolicyCreate <<DTO>> {
        source_element_id : str
        target_element_id : str?
        rule_type : RuleType
        passing_threshold : float?
        valid_from : datetime?
        valid_until : datetime?
        subpolicy_ids : list<str>?
        aggregate_elements : list<str>?
        aggregate_function : AggFn?
        restricted_to_group : str?
    }
    class ProgressEvent <<DTO>> {
        student_id : str
        element_id : str
        event_type : EventType
        value : float?
        competency_id : str?
        timestamp : datetime
    }
    class AvailableElements <<DTO>> {
        accessible : list<str>
        blocked : list<str>
    }
    class VerificationReportResponse <<DTO>> {
        consistency : СВ1Result
        acyclicity : СВ2Result
        reachability : СВ3Result
        redundancy : СВ4Result?
        subsumption : СВ5Result?
    }
    class CourseSyncPayload <<DTO>> {
        course_id : str
        modules : list<ModuleNode>
        policies : list<PolicyCreate>
    }
}

' =========================================================
' DEPENDENCIES: Controllers → Services
' =========================================================
PolicyController       ..> PolicyService
AccessController       ..> AccessService
ProgressController     ..> ProgressService
VerificationController ..> VerificationService
SandboxController      ..> SandboxService
IntegrationController  ..> IntegrationService

' =========================================================
' DEPENDENCIES: Services → Core + Services (composition)
' =========================================================
PolicyService       --> OntologyCore
PolicyService       --> ReasoningOrchestrator
PolicyService       --> CacheManager
PolicyService       ..> GraphValidator : <<uses static>>

AccessService       --> OntologyCore
AccessService       --> ReasoningOrchestrator
AccessService       --> CacheManager
AccessService       *--> AccessExplainer

VerificationService --> OntologyCore
VerificationService --> ReasoningOrchestrator
VerificationService --> CacheManager
VerificationService ..> GraphValidator : <<uses static>>

ProgressService     --> OntologyCore
ProgressService     --> ReasoningOrchestrator
ProgressService     --> RollupService
ProgressService     --> AccessService

SandboxService      --> OntologyCore
SandboxService      --> ReasoningOrchestrator
SandboxService      --> AccessService
SandboxService      --> ProgressService

RollupService       --> OntologyCore

IntegrationService  --> OntologyCore
IntegrationService  --> VerificationService
IntegrationService  --> CacheManager

' =========================================================
' Core internal
' =========================================================
ReasoningOrchestrator --> OntologyCore

' =========================================================
' DTOs consumed by controllers
' =========================================================
PolicyController       ..> PolicyCreate
ProgressController     ..> ProgressEvent
AccessController       ..> AvailableElements
VerificationController ..> VerificationReportResponse
IntegrationController  ..> CourseSyncPayload

@enduml
