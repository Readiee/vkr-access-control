%%{init: {'theme': 'default', 'themeVariables': {'fontFamily': 'Segoe UI'}}}%%
sequenceDiagram
    autonumber
    title Событие прогресса и каскадная агрегация завершённости

    participant LMS as Внешняя СДО
    participant PC as ProgressController
    participant PS as ProgressService
    participant OC as OntologyCore
    participant RS as RollupService
    participant RO as ReasoningOrchestrator
    participant AS as AccessService
    participant CM as CacheManager
    participant R as Redis
    participant OWL as Ontology Store

    LMS ->> PC : POST /events/progress<br/>{student, element, event_type, value?}
    PC  ->> PS : update_progress(student, element, status)

    rect rgb(240, 248, 255)
        note over PS,OC: Шаг 1: нормализация и запись факта
        PS ->> OC : найти студента / создать
        PS ->> OC : найти элемент курса
        alt элемент не найден
            OC -->> PS : None
            PS -->> PC : ValueError
            PC -->> LMS : 404
        end
        PS ->> OC : create_or_update ProgressRecord<br/>(refers_to_student, refers_to_element,<br/>has_grade?, has_status)
        PS ->> OC : save()
        OC ->> OWL : persist
    end

    rect rgb(245, 255, 245)
        note over PS,RS: Шаг 2: каскадная агрегация завершённости
        alt событие завершает элемент
            PS ->> RS : execute(student, just_completed=element, update_callback)

            loop пока есть родитель и все обязательные дети завершены
                RS ->> OC : найти родительский элемент
                alt родителя нет (корень)
                    OC -->> RS : None
                    note right of RS: выход из рекурсии
                else
                    OC -->> RS : parent
                    RS ->> OC : дети parent с is_mandatory=true
                    OC -->> RS : mandatory_set
                    alt mandatory_set пустой
                        note right of RS: обязательных нет, не завершаем
                    else
                        loop ∀ c ∈ mandatory_set
                            RS ->> OC : проверить is_completed(student, c)
                        end
                        alt все завершены
                            RS ->> OC : пометить parent как COMPLETED
                            note right of RS: подняться к parent
                        else
                            note right of RS: выход
                        end
                    end
                end
            end

            RS ->> OC : save()
        end
    end

    PC -->> LMS : 202 Accepted (фоновая обработка)

    rect rgb(255, 250, 240)
        note over PS,R: Шаг 3: фоновый перерасчёт логического вывода
        PS ->> RO : reason_and_materialize(student_id=student)
        activate RO
        note right of RO: Подготовка фактов → вывод<br/>через Pellet → cwa-enforcement<br/>→ материализация
        RO -->> PS : ABox обновлён
        deactivate RO
        PS ->> AS : rebuild_student_access(student)
        AS ->> CM : invalidate_student(student)
        CM ->> R  : DEL access:{student}
        AS ->> CM : set_student_access(student, new_map, ttl)
        CM ->> R  : SET access:{student}
    end
